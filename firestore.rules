rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isAuth() && exists(currentUserPath());
    }

    function currentUser() {
      return get(currentUserPath()).data;
    }

    function currentCompanyId() {
      return hasUserProfile() ? currentUser().companyId : null;
    }

    function currentRole() {
      return hasUserProfile() ? currentUser().role : null;
    }

    function isCompanyMember(companyId) {
      return isAuth() && currentCompanyId() == companyId;
    }

    function isTeamAdmin() {
      return isAuth() && currentRole() in ['super_admin', 'hr_admin'];
    }

    match /users/{userId} {
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        resource.data.companyId == currentCompanyId()
      );
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (
        request.auth.uid == userId ||
        (
          isTeamAdmin() &&
          resource.data.companyId == currentCompanyId() &&
          resource.data.role != 'super_admin' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['role', 'companyId', 'isActive', 'updatedAt'])
        )
      );
    }

    match /companies/{companyId} {
      allow read: if isCompanyMember(companyId);
      allow create: if isAuth();
      allow update: if isCompanyMember(companyId);
    }

    match /offboardTemplates/{templateId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Portal (unauthenticated) reads a flow only if it carries a portalToken
    // and the link hasn't expired. Updates must echo the stored portalToken
    // unchanged AND be confined to safe progress fields.
    match /offboardFlows/{flowId} {
      allow read, write: if isAuth();
      allow read: if resource.data.portalToken != null
        && (!('portalExpiresAt' in resource.data)
            || resource.data.portalExpiresAt == null
            || request.time < resource.data.portalExpiresAt);
      allow update: if request.resource.data.portalToken == resource.data.portalToken
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['progressPercent', 'completionScores', 'status', 'portalLastAccessed']);

      // Audit log is read-only for company members and write-only via
      // Cloud Functions (admin SDK bypasses rules). Deny all client writes
      // so entries are tamper-evident.
      match /auditLog/{entryId} {
        allow read: if isAuth()
          && get(/databases/$(database)/documents/offboardFlows/$(flowId)).data.companyId == currentCompanyId();
        allow write: if false;
      }
    }

    // Portal updates a task only if the task carries the same portalToken as
    // its parent flow (denormalized at creation time) and only completion-
    // related fields are touched.
    match /flowTasks/{taskId} {
      allow read, write: if isAuth();
      allow read: if resource.data.portalToken != null;
      allow update: if request.resource.data.portalToken == resource.data.portalToken
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'completedAt', 'completedBy', 'uploadedFileUrl']);
    }

    match /notifications/{notificationId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /systemCatalog/{catalogId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /accessRevocations/{revocationId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /assets/{assetId} {
      allow read: if isAuth() && resource.data.companyId == currentCompanyId();
      allow create: if isAuth() && request.resource.data.companyId == currentCompanyId();
      allow update, delete: if isAuth() && resource.data.companyId == currentCompanyId();
    }

    // Portal reads interview templates (not sensitive) and submits responses.
    match /exitInterviewTemplates/{templateId} {
      allow read, write: if isAuth();
      allow read: if true;
    }

    // Portal submits and reads its own responses to check completion status.
    // Anonymous creates require a flowId + matching portalToken so attackers
    // can't spam arbitrary companies / trigger AI sentiment analysis.
    match /exitInterviewResponses/{responseId} {
      allow read, write: if isAuth();
      allow read: if resource.data.portalToken != null;
      allow create: if request.resource.data.flowId is string
        && request.resource.data.companyId is string
        && request.resource.data.portalToken is string
        && request.resource.data.portalToken ==
           get(/databases/$(database)/documents/offboardFlows/$(request.resource.data.flowId)).data.portalToken;
    }

    // Portal submits knowledge items; same guardrails as exit interview.
    match /knowledgeItems/{itemId} {
      allow read, write: if isAuth();
      allow read: if resource.data.portalToken != null;
      allow create: if request.resource.data.flowId is string
        && request.resource.data.companyId is string
        && request.resource.data.portalToken is string
        && request.resource.data.portalToken ==
           get(/databases/$(database)/documents/offboardFlows/$(request.resource.data.flowId)).data.portalToken;
    }

    match /alumniProfiles/{profileId} {
      // Any authenticated user can create an alumni profile
      allow create: if isAuth();
      // Any authenticated user can read (needed for email-based list queries)
      allow read: if isAuth();
      // Company members and the alumni themselves can update
      allow update: if isAuth() && (
        resource.data.companyId == currentCompanyId() ||
        (request.auth.token.email != null && resource.data.email == request.auth.token.email)
      );
      // Only company members can delete
      allow delete: if isAuth() && resource.data.companyId == currentCompanyId();
    }

    // Outbound HRIS / identity-provider webhooks. Read/write limited to
    // team admins because secrets live here.
    match /integrations/{integrationId} {
      allow read: if isAuth() && resource.data.companyId == currentCompanyId();
      allow create: if isTeamAdmin()
        && request.resource.data.companyId == currentCompanyId();
      allow update, delete: if isTeamAdmin()
        && resource.data.companyId == currentCompanyId();
    }

    // Compliance report archive. Only generated server-side; clients are
    // read-only.
    match /complianceReports/{reportId} {
      allow read: if isTeamAdmin()
        && resource.data.companyId == currentCompanyId();
      allow write: if false;
    }

    match /invites/{inviteId} {
      allow read: if isAuth() && (
        resource.data.email == request.auth.token.email ||
        resource.data.companyId == currentCompanyId()
      );
      allow create: if isTeamAdmin() && request.resource.data.companyId == currentCompanyId();
      allow update: if isAuth() && (
        resource.data.email == request.auth.token.email ||
        resource.data.companyId == currentCompanyId()
      );
      allow delete: if isAuth() && (
        (isTeamAdmin() && resource.data.companyId == currentCompanyId()) ||
        resource.data.invitedBy == request.auth.uid
      );
    }
  }
}
