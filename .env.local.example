# Firebase (required) — copy from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Analytics (optional)
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# --- Cloud Functions environment variables ---
# Set these with: firebase functions:config:set key=value
# Or use .env files in the functions/ directory (Gen 2) or Firebase secret manager

# Brevo SMTP — Settings → SMTP & API → SMTP tab
BREVO_SMTP_USER=your_smtp_login@smtp-brevo.com
BREVO_SMTP_KEY=your_brevo_smtp_password

# Google Gemini API — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Public URL of the deployed app (used in email links)
APP_URL=https://your-project.web.app
