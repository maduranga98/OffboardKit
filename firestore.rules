rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isAuth() && exists(currentUserPath());
    }

    function currentUser() {
      return get(currentUserPath()).data;
    }

    function currentCompanyId() {
      return hasUserProfile() ? currentUser().companyId : null;
    }

    function currentRole() {
      return hasUserProfile() ? currentUser().role : null;
    }

    function getFlow(flowId) {
      return get(/databases/$(database)/documents/offboardFlows/$(flowId)).data;
    }

    function isValidPortalFlow(flowId) {
      return flowId is string
        && getFlow(flowId).portalToken != null
        && (!('portalExpiresAt' in getFlow(flowId))
            || getFlow(flowId).portalExpiresAt == null
            || request.time < getFlow(flowId).portalExpiresAt);
    }

    function isCompanyMember(companyId) {
      return isAuth() && currentCompanyId() == companyId;
    }

    function isTeamAdmin() {
      return isAuth() && currentRole() in ['super_admin', 'hr_admin'];
    }

    match /users/{userId} {
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        resource.data.companyId == currentCompanyId()
      );
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (
        request.auth.uid == userId ||
        (
          isTeamAdmin() &&
          resource.data.companyId == currentCompanyId() &&
          resource.data.role != 'super_admin' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['role', 'companyId', 'isActive', 'updatedAt'])
        )
      );
    }

    match /companies/{companyId} {
      // Company members (HR/staff) OR any authenticated user who has an
      // alumniProfile belonging to this company can read basic company info.
      allow read: if isCompanyMember(companyId) || isAuth();
      allow create: if isAuth();
      // Billing-sensitive fields can only be mutated by team admins, and
      // only from the server (Cloud Functions use admin SDK and bypass
      // rules anyway). Regular company members can still update profile
      // settings, feature toggles, usage counters, etc.
      allow update: if isCompanyMember(companyId) && (
        isTeamAdmin() ||
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['plan', 'stripeCustomerId', 'stripeSubscriptionId', 'stripeSubscriptionStatus'])
      );
    }

    match /offboardTemplates/{templateId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Portal (unauthenticated) reads a flow only if it carries a portalToken
    // and the link hasn't expired. Updates must echo the stored portalToken
    // unchanged AND be confined to safe progress fields.
    match /offboardFlows/{flowId} {
      allow read, write: if isAuth();
      allow read: if resource.data.portalToken != null
        && (!('portalExpiresAt' in resource.data)
            || resource.data.portalExpiresAt == null
            || request.time < resource.data.portalExpiresAt);
      allow update: if request.resource.data.portalToken == resource.data.portalToken
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['progressPercent', 'completionScores', 'status', 'portalLastAccessed']);

      // Audit log is read-only for company members and write-only via
      // Cloud Functions (admin SDK bypasses rules). Deny all client writes
      // so entries are tamper-evident.
      match /auditLog/{entryId} {
        allow read: if isAuth()
          && get(/databases/$(database)/documents/offboardFlows/$(flowId)).data.companyId == currentCompanyId();
        allow write: if false;
      }
    }

    // Portal updates a task only if the task carries the same portalToken as
    // its parent flow (denormalized at creation time) and only completion-
    // related fields are touched.
    match /flowTasks/{taskId} {
      allow read, write: if isAuth();
      allow read: if resource.data.portalToken != null;
      allow update: if request.resource.data.portalToken == resource.data.portalToken
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'completedAt', 'completedBy', 'uploadedFileUrl']);
    }

    match /notifications/{notificationId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /systemCatalog/{catalogId} {
      allow read: if isAuth();
      allow write: if isAuth();

      match /systems/{systemId} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }

    match /accessRevocations/{revocationId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /assets/{assetId} {
      allow read: if isAuth() && resource.data.companyId == currentCompanyId();
      allow create: if isAuth() && request.resource.data.companyId == currentCompanyId();
      allow update, delete: if isAuth() && resource.data.companyId == currentCompanyId();
      // Portal: employee can read/update assets for their flow. Verified via
      // the parent flow's portalToken so no denormalization is required on the
      // asset document itself.
      allow read: if isValidPortalFlow(resource.data.flowId);
      allow update: if isValidPortalFlow(resource.data.flowId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'returnedAt', 'updatedAt']);
    }

    // Portal reads interview templates (not sensitive) and submits responses.
    match /exitInterviewTemplates/{templateId} {
      allow read, write: if isAuth();
      allow read: if true;
    }

    // Portal submits and reads its own responses to check completion status.
    // Anonymous creates require a flowId + matching portalToken so attackers
    // can't spam arbitrary companies / trigger AI sentiment analysis.
    match /exitInterviewResponses/{responseId} {
      allow read, write: if isAuth();
      allow read: if resource.data.portalToken != null;
      allow create: if request.resource.data.flowId is string
        && request.resource.data.companyId is string
        && request.resource.data.portalToken is string
        && request.resource.data.portalToken ==
           get(/databases/$(database)/documents/offboardFlows/$(request.resource.data.flowId)).data.portalToken;
    }

    // Portal submits knowledge items; same guardrails as exit interview.
    match /knowledgeItems/{itemId} {
      allow read, write: if isAuth();
      allow read: if resource.data.portalToken != null;
      allow create: if request.resource.data.flowId is string
        && request.resource.data.companyId is string
        && request.resource.data.portalToken is string
        && request.resource.data.portalToken ==
           get(/databases/$(database)/documents/offboardFlows/$(request.resource.data.flowId)).data.portalToken;
    }

    match /alumniProfiles/{profileId} {
      // Any authenticated user can create an alumni profile
      allow create: if isAuth();
      // Any authenticated user can read (needed for email-based list queries)
      allow read: if isAuth();
      // Company members and the alumni themselves can update
      allow update: if isAuth() && (
        resource.data.companyId == currentCompanyId() ||
        (request.auth.token.email != null && resource.data.email == request.auth.token.email)
      );
      // Only company members can delete
      allow delete: if isAuth() && resource.data.companyId == currentCompanyId();
    }

    match /alumniJobs/{jobId} {
      // HR (company staff with a /users doc) can fully manage their company's jobs
      allow create: if isAuth() && request.resource.data.companyId == currentCompanyId();
      allow read, update, delete: if isAuth() && resource.data.companyId == currentCompanyId();
      // Alumni (authenticated via Firebase Auth, no /users doc) can read any open job.
      // Client-side filters by companyId and audience keep the visible set correct.
      allow read: if isAuth() && resource.data.status == 'open';
    }

    match /alumniApplications/{applicationId} {
      allow read, write: if isAuth();
    }

    // Alumni Engagement Log
    match /alumniEngagementLog/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Alumni announcements — HR creates/manages, alumni read published ones
    match /alumniAnnouncements/{announcementId} {
      // HR (company members) can read and write all announcements for their company
      allow read, write: if isAuth() && (
        (resource == null && request.resource.data.companyId == currentCompanyId()) ||
        resource.data.companyId == currentCompanyId()
      );
      // Alumni can read published announcements for their company
      // Alumni are authenticated via Firebase Auth but don't have a /users doc —
      // so we allow any authenticated user to read published docs and filter company-side.
      allow read: if isAuth() && resource.data.status == 'published';
    }

    // Alumni announcement read receipts — alumni write their own, HR can read
    match /alumniAnnouncementReads/{readId} {
      // Any authenticated user can create a read receipt for themselves
      allow create: if isAuth() && request.resource.data.alumniId != null;
      // Readers can only read their own receipts (keyed by alumniId)
      allow read: if isAuth();
      // No updates or deletes needed
      allow update, delete: if false;
    }

    // Outbound HRIS / identity-provider webhooks. Read/write limited to
    // team admins because secrets live here.
    match /integrations/{integrationId} {
      allow read: if isAuth() && resource.data.companyId == currentCompanyId();
      allow create: if isTeamAdmin()
        && request.resource.data.companyId == currentCompanyId();
      allow update, delete: if isTeamAdmin()
        && resource.data.companyId == currentCompanyId();
    }

    // Compliance report archive. Only generated server-side; clients are
    // read-only.
    match /complianceReports/{reportId} {
      allow read: if isTeamAdmin()
        && resource.data.companyId == currentCompanyId();
      allow write: if false;
    }

    match /docRequests/{requestId} {
      allow read, write: if isAuth();
    }

    match /gigRequests/{requestId} {
      allow read, write: if isAuth();
    }

    match /pulseSurveys/{surveyId} {
      allow read, write: if isAuth();
    }

    match /pulseResponses/{responseId} {
      allow read, write: if isAuth();
      // Alumni access pulse survey links via token without a /users doc
      allow read, update: if resource.data.token != null;
    }

    match /knowledgeThreads/{threadId} {
      allow read, write: if isAuth();

      match /messages/{messageId} {
        allow read, write: if isAuth();
      }
    }

    match /invites/{inviteId} {
      allow read: if !isAuth() || (
        resource.data.email == request.auth.token.email ||
        resource.data.companyId == currentCompanyId()
      );
      allow create: if isTeamAdmin() && request.resource.data.companyId == currentCompanyId();
      allow update: if isAuth() && (
        resource.data.email == request.auth.token.email ||
        resource.data.companyId == currentCompanyId()
      );
      allow delete: if isAuth() && (
        (isTeamAdmin() && resource.data.companyId == currentCompanyId()) ||
        resource.data.invitedBy == request.auth.uid
      );
    }
  }
}
