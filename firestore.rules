rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function isCompanyMember(companyId) {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
    }

    match /companies/{companyId} {
      allow read: if isCompanyMember(companyId);
      allow create: if isAuth();
      allow update: if isCompanyMember(companyId);
    }

    match /offboardTemplates/{templateId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Portal (unauthenticated) needs to read flows by portalToken and update
    // progress fields. Field-level restriction limits portal updates to safe fields only.
    match /offboardFlows/{flowId} {
      allow read, write: if isAuth();
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['progressPercent', 'completionScores', 'status', 'portalLastAccessed']);
    }

    // Portal needs to read and complete tasks assigned to the employee.
    // Update is restricted to completion-related fields only.
    match /flowTasks/{taskId} {
      allow read, write: if isAuth();
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'completedAt', 'completedBy', 'uploadedFileUrl']);
    }

    match /notifications/{notificationId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /systemCatalog/{catalogId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /accessRevocations/{revocationId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Portal reads interview templates (not sensitive) and submits responses.
    match /exitInterviewTemplates/{templateId} {
      allow read, write: if isAuth();
      allow read: if true;
    }

    // Portal submits and reads its own responses to check completion status.
    match /exitInterviewResponses/{responseId} {
      allow read, write: if isAuth();
      allow create: if true;
      allow read: if true;
    }

    // Portal submits knowledge items and reads them to show completion status.
    match /knowledgeItems/{itemId} {
      allow read, write: if isAuth();
      allow create: if true;
      allow read: if true;
    }

    match /alumniProfiles/{profileId} {
      allow read: if isAuth();
      allow write: if isAuth();
      // Alumni can read/update only their own profile
      allow read: if isAuth() && resource.data.email == request.auth.token.email;
      allow update: if isAuth() && resource.data.email == request.auth.token.email;
    }

    match /invites/{inviteId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }
  }
}
